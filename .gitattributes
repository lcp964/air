# Set default behavior to automatically normalize line endings.
* text=auto eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Web files should use LF
*.js text eol=lf
*.vue text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
